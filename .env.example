# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth Migration Flags
# Setează pe 'true' pentru a permite login-ul vechi (plain text / hardcoded)
# Setează pe 'false' pentru a forța utilizarea Supabase Auth
VITE_ALLOW_LEGACY_LOGIN=false
