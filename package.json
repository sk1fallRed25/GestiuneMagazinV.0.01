{
  "name": "sistem-magazin",
  "productName": "Sistem Gestiune Magazin",
  "private": true,
  "version": "1.0.0",
  "description": "Aplicatie de gestiune stocuri si vanzari",
  "author": "Stefan",
  "main": "electron-main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.18",
    "@mui/material": "^5.14.18",
    "@mui/x-data-grid": "^6.18.1",
    "@supabase/supabase-js": "^2.38.4",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "supabase": "^2.72.8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^7.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gestiunemagazin.app",
    "productName": "Sistem Gestiune Magazin",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "electron-preload.js",
      "electron-updater-service.js",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "sk1fallRed25",
      "repo": "GestiuneMagazinV.0.01"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sistem Gestiune Magazin",
      "runAfterFinish": true
    }
  }
}
